{
  "Telemetry": {
    "SchemaVersion": 1,
    "bEnabled": true,
    "IntervalSeconds": 0.2,
    "OutputRelativePath": "Saved/Telemetry/telemetry.jsonl",
    "OutputDirectoryRelativePath": "Saved/Telemetry/Runs",
    "OutputFilePrefix": "telemetry",
    "bCreateTimestampedFilePerRun": true,
    "bOverwriteOnStart": true,
    "bIncludeUtcTimestamp": true,
    "bIncludeSimulationTime": true,
    "bIncludePawnVelocity": true,
    "PawnTag": "TrainingPawn",
    "TrackedActorTags": [
      "TrainingTarget",
      "SpawnedAsset"
    ],
    "MaxTrackedActors": 64,
    "bIncludeTelemetryProviders": true
  }
}
